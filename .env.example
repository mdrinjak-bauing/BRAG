# Academic RAG and Second Brain — configuration.
# The setup wizard writes a .env file for you; this file documents every option.
# After changing values: docker compose up -d --force-recreate

# ── Profile: gemini | openai | anthropic | hybrid | local ───────
# The profile picks the TEXT LLM (used for context generation, image
# descriptions, classification). Embeddings are LOCAL in every profile
# (arctic, CPU) — so you can switch the LLM provider below WITHOUT
# re-indexing your corpus.
#   gemini/openai/anthropic = cloud LLM (need an API key).
#   hybrid/local            = on-device LLM (LM Studio / Ollama).
# ("cloud" is still accepted as an alias for "gemini".)
PROFILE=gemini

# ── Cloud API keys — only the active provider's key is needed ──
# Gemini (free):   https://aistudio.google.com/apikey
# OpenAI:          https://platform.openai.com/api-keys
# Anthropic/Claude https://console.anthropic.com/
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Vault location (host path, default: ./vault inside this folder) ─
VAULT_PATH=./vault

# ── Language of your documents (Snowball stemmer name: english, german,
#    french, spanish, italian, dutch, ...) and language for AI-generated text
VAULT_LANGUAGE=english
ANSWER_LANGUAGE=English

# ── Advanced overrides (defaults come from the chosen profile) ──
#
# Fast cloud embeddings (opt-in): by default embeddings run locally on CPU.
# On weak hardware with a large corpus, a cloud embedding API is much faster.
# Uncomment ONE block. NOTE: changing the embedding backend/dimension means a
# one-time full re-ingest (the corpus lands in a new, separate collection).
#   Gemini:  EMBEDDING_BACKEND=gemini   EMBEDDING_MODEL=gemini-embedding-001       EMBEDDING_DIM=3072
#   OpenAI:  EMBEDDING_BACKEND=openai   EMBEDDING_MODEL=text-embedding-3-small     EMBEDDING_DIM=1536
# (Anthropic has no embedding API — there is no cloud-embedding option for it.)
#
# LLM overrides:
# LLM_BACKEND=gemini                # gemini | openai | anthropic | openai_compatible
# LLM_MODEL=gemini-2.5-flash-lite   # default: no daily request cap (bulk-safe).
#                                   # gemini-2.5-flash = better quality, but
#                                   # capped at 10k requests/day — fine AFTER
#                                   # your initial corpus is indexed.
# LLM_BASE_URL=                     # e.g. http://host.docker.internal:1234/v1

# ── Retrieval tuning (defaults are empirically validated) ───────
# RERANK_ENABLED=true
# RERANK_PREFETCH=150
# RERANK_FUSION_LIMIT=80
# DEFAULT_TOP_K=15
# MAX_CHUNKS_PER_SOURCE=3

# ── Contextual retrieval ────────────────────────────────────────
# CR_ENABLED=true
# CR_BATCH_SIZE=5
