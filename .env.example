# BRAG — Building Retrieval-Augmented Generation — configuration.
# The setup wizard writes a .env file for you; this file documents every option.
# After changing values: docker compose up -d --force-recreate

# ── Profile: gemini | openai | anthropic | hybrid ──────────────
# The profile picks the TEXT LLM (used for context generation and image
# descriptions). The doc type is derived from the folder path, not from an
# LLM (no cloud transfer). Embeddings are LOCAL in every profile
# (arctic, CPU) — so you can switch the LLM provider below WITHOUT
# re-indexing your corpus.
#   gemini/openai/anthropic = cloud LLM (need an API key).
#   hybrid                  = on-device LLM (LM Studio).
# ("cloud" is still accepted as an alias for "gemini".)
PROFILE=gemini

# ── Cloud API keys — only the active provider's key is needed ──
# Gemini (free):   https://aistudio.google.com/apikey
# OpenAI:          https://platform.openai.com/api-keys
# Anthropic/Claude https://console.anthropic.com/
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Knowledge store location (host path, default: ./WissensWIKI) ─
VAULT_PATH=./WissensWIKI

# ── Language of your documents (Snowball stemmer name: english, german,
#    french, spanish, italian, dutch, ...) and language for AI-generated text
VAULT_LANGUAGE=english
ANSWER_LANGUAGE=English

# ── Advanced overrides (defaults come from the chosen profile) ──
#
# Fast cloud embeddings (opt-in): by default embeddings run locally on CPU.
# On weak hardware with a large corpus, a cloud embedding API is much faster.
# Uncomment ONE block. NOTE: changing the embedding backend/dimension means a
# one-time full re-ingest (the corpus lands in a new, separate collection; the
# app re-ingests sources/ automatically on next start). The OLD collection is
# left behind and keeps using disk — the app logs its name on startup; drop it
# deliberately (Qdrant dashboard at http://localhost:6333/dashboard) once sure.
#   Gemini:  EMBEDDING_BACKEND=gemini   EMBEDDING_MODEL=gemini-embedding-001       EMBEDDING_DIM=3072
#   OpenAI:  EMBEDDING_BACKEND=openai   EMBEDDING_MODEL=text-embedding-3-small     EMBEDDING_DIM=1536
# (Anthropic has no embedding API — there is no cloud-embedding option for it.)
#
# LLM overrides:
# LLM_BACKEND=gemini                # gemini | openai | anthropic | openai_compatible
# LLM_MODEL=gemini-2.5-flash-lite   # default: no daily request cap (bulk-safe).
#                                   # gemini-2.5-flash = better quality, but
#                                   # capped at 10k requests/day — fine AFTER
#                                   # your initial corpus is indexed.
# LLM_BASE_URL=                     # e.g. http://host.docker.internal:1234/v1

# Pin the local model weights to an exact Hugging Face revision (commit SHA or
# tag) for reproducible, supply-chain-safe downloads. Empty = latest.
# EMBEDDING_REVISION=
# RERANKER_REVISION=

# ── Search speed vs. quality (the reranker is the main CPU cost) ─
# RERANK_PROFILE picks how hard the LOCAL cross-encoder reranker works:
#   off       reranking disabled — fastest, lowest quality (RRF fusion only)
#   eco       load 160 (80+80),   rerank 40   ← DEFAULT, gentle on consumer PCs
#   balanced  load 240 (120+120), rerank 60
#   full      load 400 (200+200), rerank 120  ← strong machines, best quality
# If searches feel slow, set "off" or "eco"; on a strong PC try "full".
# RERANK_PROFILE=eco
#
# Fine-grained overrides (take precedence over the profile above):
# RERANK_ENABLED=true        # false = never rerank, regardless of profile
# RERANK_PREFETCH=80         # candidates pulled PER vector (dense, sparse)
# RERANK_FUSION_LIMIT=40     # passages the cross-encoder actually scores
# RERANK_BATCH_SIZE=16       # cross-encoder batch size (peak memory / latency)
# DEFAULT_TOP_K=15
# MAX_CHUNKS_PER_SOURCE=3

# ── Contextual retrieval ────────────────────────────────────────
# Every chunk gets 1-2 LLM-generated sentences of grounding context before
# embedding. The defaults below are PROFILE-AWARE: cloud profiles get generous
# sizes (huge context windows); the local profile (hybrid via LM Studio) gets
# tight sizes so the prompt fits a small on-device window — an
# oversized prompt makes a local server return HTTP 400 for every batch and
# produce zero context. Override only if you know your local model's window.
# CR_ENABLED=true
# CR_BATCH_SIZE=5            # chunks per LLM call (local default 3)
# CONTEXT_DOC_CHARS=15000    # whole-document fallback grounding (local 4000)
# CHAPTER_CONTEXT_CHARS=10000 # matched-chapter grounding         (local 3000)
# TOC_MAX_CHARS=3000         # table-of-contents grounding         (local 1500)
# CR_PROMPT_MAX_CHARS=60000  # HARD cap on the whole assembled prompt; the
#                            # grounding block is trimmed to fit. Local default
#                            # 9000 (sized for a ~4k-token on-device window). If
#                            # your local model has a larger window (e.g. 8k),
#                            # raise this for richer grounding.

# ── Vision pass (figure descriptions) ───────────────────────────
# On by default: each figure's image is sent to the (multimodal) text LLM for
# an honest 1-3 sentence description, embedded so figures are findable by
# content. All cloud presets are multimodal; for local profiles load a vision
# model (else it safely falls back to caption-only). Set to false to skip it
# (also skips rendering figure images, making extraction a bit faster).
# VISION_ENABLED=true
# VISION_IMAGE_SCALE=2.0            # render resolution for figure images

# ── HTTP bridge port (only change on a port conflict) ───────────
# The local HTTP bridge serves the setup wizard and the page-precise PDF
# deep-links in answers. The default port is 8765. If another program already
# uses it, override BOTH variables together — the host port and the public URL
# MUST match, because BRIDGE_PUBLIC_URL is what gets baked into the clickable
# PDF links in answers. Change only the port number, keep the rest as-is.
# BRIDGE_HOST_PORT=8765
# BRIDGE_PUBLIC_URL=http://localhost:8765
